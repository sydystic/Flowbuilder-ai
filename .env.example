# === Server ===
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# === Authentication (Supabase) ===
# Used for real database sync and authorization if DEMO_MODE is false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Frontend (Vite, compiled at build time) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_DEMO_MODE=true

# === Demo Mode (bypasses real auth + uses local JSON DB) ===
DEMO_MODE=true
DEMO_TOKEN=demo-token

# === Encryption (must resolve to exactly 32 bytes) ===
# Generate secure base64: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# You can also use a raw 32-character string or 64-character hex string.
ENCRYPTION_KEY=

# === AI Providers ===
GEMINI_API_KEY=
GROQ_API_KEY=

# === n8n ===
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_TIMEOUT_MS=10000
N8N_PUBLIC_URL=http://localhost:5678/

# === CORS (comma-separated allowed origins) ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# === Docker / Postgres ===
POSTGRES_USER=flowbuilder
POSTGRES_PASSWORD=change-me
POSTGRES_DB=flowbuilder
N8N_USER=admin
N8N_PASSWORD=change-me
